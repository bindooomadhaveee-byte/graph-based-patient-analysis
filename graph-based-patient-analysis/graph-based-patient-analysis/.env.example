# App
APP_NAME=graph-based-patient-analysis
LOG_LEVEL=INFO

# Similarity weights (must sum to 1.0)
SIM_WEIGHT_DIAGNOSIS=0.5
SIM_WEIGHT_MEDICATION=0.3
SIM_WEIGHT_DEMOGRAPHIC=0.2

# Data
DEFAULT_DATA_PATH=data/sample_patients.json

# Neo4j (optional persistent backend, not required for base project)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
USE_NEO4J=false
